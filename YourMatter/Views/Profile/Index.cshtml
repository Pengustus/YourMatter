@model YourMatter.Data.Models.ApplicationUser
@using YourMatter.Data.Models
@using Microsoft.AspNetCore.Identity
@inject UserManager<ApplicationUser> UserManager
@{
    ViewData["Title"] = Model.DisplayName + "'s Profile";
    var currentUser = await UserManager.GetUserAsync(User);
    var isOwnProfile = currentUser != null && currentUser.Id == Model.Id;
    var posts = ViewBag.Posts as IEnumerable<Post> ?? new List<Post>();
    var friends = ViewBag.Friends as IEnumerable<ApplicationUser> ?? new List<ApplicationUser>();
    var friendshipStatus = ViewBag.FriendshipStatus as FriendRequestStatus?;
}

<div class="row">
    <!-- Left Column: Profile Info & Friends -->
    <div class="col-lg-4 mb-4">
        <div class="custom-card text-center border-top border-4 border-primary">
            <img src="@(string.IsNullOrEmpty(Model.ProfilePictureUrl) ? "/images/default_profile.png" : Model.ProfilePictureUrl)" 
                 alt="@Model.DisplayName's avatar" class="profile-sidebar-img" />
            
            <h2 class="profile-name">@Model.DisplayName</h2>
            <p class="text-muted small mb-3">Member since @Model.CreatedOn.ToString("MMMM yyyy")</p>

            @if (isOwnProfile)
            {
                <a asp-controller="Profile" asp-action="Edit" class="btn btn-retro-outline btn-sm w-100 mb-2">
                    <i class="bi bi-pencil-square me-1"></i>Edit My Profile
                </a>
            }
            else if (currentUser != null)
            {
                <div class="my-3">
                    @if (friendshipStatus == null)
                    {
                        <form asp-controller="Friends" asp-action="SendRequest" method="post">
                            <input type="hidden" name="receiverId" value="@Model.Id" />
                            <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                            <button type="submit" class="btn btn-retro-primary btn-sm w-100">
                                <i class="bi bi-person-plus-fill me-1"></i>Add to Friends
                            </button>
                        </form>
                    }
                    else if (friendshipStatus == FriendRequestStatus.Pending)
                    {
                        <!-- Let's check if current user is the sender or receiver of the pending request -->
                        @* We can determine this by checking if the request was sent by current user *@
                        <div class="p-2 bg-light rounded text-center mb-2">
                            <span class="text-accent fw-semibold small"><i class="bi bi-clock-history me-1"></i>Friendship Pending</span>
                        </div>
                        
                        <form asp-controller="Friends" asp-action="DeclineOrCancelRequest" method="post" class="d-inline">
                            <input type="hidden" name="otherUserId" value="@Model.Id" />
                            <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                            <button type="submit" class="btn btn-outline-danger btn-sm w-100">
                                <i class="bi bi-x-circle me-1"></i>Cancel / Decline Request
                            </button>
                        </form>
                    }
                    else if (friendshipStatus == FriendRequestStatus.Accepted)
                    {
                        <div class="p-2 bg-light rounded text-center mb-2">
                            <span class="text-success fw-semibold small"><i class="bi bi-people-fill me-1"></i>You are Friends</span>
                        </div>
                        <form asp-controller="Friends" asp-action="DeclineOrCancelRequest" method="post">
                            <input type="hidden" name="otherUserId" value="@Model.Id" />
                            <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                            <button type="submit" class="btn btn-outline-danger btn-sm w-100" onclick="return confirm('Remove friend?');">
                                <i class="bi bi-person-dash-fill me-1"></i>Remove Friend
                            </button>
                        </form>
                    }
                </div>
            }

            <hr />

            <ul class="profile-details-list text-start">
                <li>
                    <strong>Location:</strong>
                    <span class="text-secondary">@(string.IsNullOrEmpty(Model.Location) ? "Not Specified" : Model.Location)</span>
                </li>
                <li>
                    <strong>Email:</strong>
                    <span class="text-secondary">@Model.Email</span>
                </li>
            </ul>
        </div>

        <!-- Bio Card -->
        <div class="custom-card border-top border-4 border-accent">
            <div class="panel-header-retro panel-header-orange">
                <span><i class="bi bi-chat-quote-fill me-2"></i>About Me</span>
            </div>
            <p class="mb-0 text-start" style="white-space: pre-line;">
                @(string.IsNullOrEmpty(Model.Bio) ? "Hi, I haven't written a biography yet!" : Model.Bio)
            </p>
        </div>

        <!-- Friends Card (Nostalgic MySpace Top Friends) -->
        <div class="custom-card">
            <div class="panel-header-retro">
                <span><i class="bi bi-people-fill me-2"></i>Friend Space</span>
                <span class="badge bg-white text-primary">@friends.Count()</span>
            </div>
            
            @if (!friends.Any())
            {
                <p class="text-muted small mb-0">No friends added yet.</p>
            }
            else
            {
                <div class="friends-grid">
                    @foreach (var friend in friends)
                    {
                        <div class="friend-item-card">
                            <a asp-controller="Profile" asp-action="Index" asp-route-id="@friend.Id">
                                <img src="@(string.IsNullOrEmpty(friend.ProfilePictureUrl) ? "/images/default_profile.png" : friend.ProfilePictureUrl)" 
                                     alt="@friend.DisplayName" class="friend-avatar-thumb" />
                            </a>
                            <a asp-controller="Profile" asp-action="Index" asp-route-id="@friend.Id" class="friend-name-link">
                                @friend.DisplayName
                            </a>
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    <!-- Right Column: Post Input & Wall -->
    <div class="col-lg-8">
        @if (isOwnProfile)
        {
            <!-- Post Creation Area -->
            <div class="custom-card mb-4 border-start border-4 border-primary">
                <h4 class="mb-3">Update your Status / Post to Wall</h4>
                <form asp-controller="Post" asp-action="Create" method="post">
                    <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                    <div class="mb-3">
                        <textarea class="form-control" name="content" rows="3" placeholder="What is on your mind?..." required></textarea>
                    </div>
                    <div class="text-end">
                        <button type="submit" class="btn btn-retro-primary btn-sm">
                            <i class="bi bi-send-fill me-1"></i>Publish Post
                        </button>
                    </div>
                </form>
            </div>
        }

        <h3 class="mb-3 border-bottom pb-2">@Model.DisplayName's Wall Posts</h3>

        @if (!posts.Any())
        {
            <div class="custom-card text-center py-5">
                <i class="bi bi-postcard text-muted display-4"></i>
                <p class="text-muted mt-2">No wall posts yet.</p>
            </div>
        }
        else
        {
            @foreach (var post in posts)
            {
                var userLiked = currentUser != null && post.Likes.Any(l => l.UserId == currentUser.Id);
                var isAdmin = User.IsInRole("Administrator");
                var canDeletePost = currentUser != null && (post.AuthorId == currentUser.Id || isAdmin);

                <div class="custom-card post-card @(post.Author.Email == "admin@yourmatter.com" ? "post-card-admin" : "") animate-fade-in" id="post-@post.Id">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div class="d-flex align-items-center">
                            <img src="@(string.IsNullOrEmpty(post.Author.ProfilePictureUrl) ? "/images/default_profile.png" : post.Author.ProfilePictureUrl)" 
                                 alt="@post.Author.DisplayName" class="post-author-avatar me-3" />
                            <div>
                                <h5 class="mb-0">
                                    <a asp-controller="Profile" asp-action="Index" asp-route-id="@post.AuthorId" class="text-decoration-none text-dark fw-bold">
                                        @post.Author.DisplayName
                                    </a>
                                </h5>
                                <span class="post-meta">@post.CreatedOn.ToLocalTime().ToString("g")</span>
                            </div>
                        </div>

                        @if (canDeletePost)
                        {
                            <form asp-controller="Post" asp-action="Delete" method="post" class="d-inline" onsubmit="return confirm('Delete this post?');">
                                <input type="hidden" name="id" value="@post.Id" />
                                <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                                <button type="submit" class="btn btn-outline-danger btn-sm border-0" title="Delete post">
                                    <i class="bi bi-trash3-fill"></i>
                                </button>
                            </form>
                        }
                    </div>

                    <div class="post-content-text mb-3">@post.Content</div>

                    <div class="d-flex align-items-center gap-2 border-top pt-3">
                        @if (currentUser != null)
                        {
                            <button class="btn btn-like-ajax @(userLiked ? "liked" : "") d-flex align-items-center gap-2" 
                                    data-post-id="@post.Id">
                                <i class="bi @(userLiked ? "bi-heart-fill" : "bi-heart")"></i>
                                <span class="likes-count">@post.Likes.Count</span>
                            </button>
                        }
                        else
                        {
                            <span class="btn-like-ajax disabled d-flex align-items-center gap-2">
                                <i class="bi bi-heart"></i>
                                <span>@post.Likes.Count</span>
                            </span>
                        }
                    </div>

                    <!-- Comments Area -->
                    <div class="comments-container mt-3">
                        <h6 class="fw-bold mb-2"><i class="bi bi-chat-text-fill me-1"></i> Comments</h6>
                        
                        @if (post.Comments.Any())
                        {
                            @foreach (var comment in post.Comments.OrderBy(c => c.CreatedOn))
                            {
                                var canDeleteComment = currentUser != null && (comment.AuthorId == currentUser.Id || post.AuthorId == currentUser.Id || isAdmin);

                                <div class="comment-item d-flex justify-content-between align-items-start py-2">
                                    <div class="d-flex gap-2">
                                        <img src="@(string.IsNullOrEmpty(comment.Author.ProfilePictureUrl) ? "/images/default_profile.png" : comment.Author.ProfilePictureUrl)" 
                                             alt="@comment.Author.DisplayName" class="comment-avatar" />
                                        <div>
                                            <div class="bg-white p-2 rounded shadow-sm">
                                                <a asp-controller="Profile" asp-action="Index" asp-route-id="@comment.AuthorId" class="fw-bold text-decoration-none small d-block">
                                                    @comment.Author.DisplayName
                                                </a>
                                                <span class="small">@comment.Content</span>
                                            </div>
                                            <small class="text-muted d-block ps-1" style="font-size: 0.75rem;">@comment.CreatedOn.ToLocalTime().ToString("g")</small>
                                        </div>
                                    </div>

                                    @if (canDeleteComment)
                                    {
                                        <form asp-controller="Post" asp-action="DeleteComment" method="post" class="d-inline" onsubmit="return confirm('Delete this comment?');">
                                            <input type="hidden" name="id" value="@comment.Id" />
                                            <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                                            <button type="submit" class="btn btn-sm btn-link text-danger border-0 p-0 me-2" title="Delete comment">
                                                <i class="bi bi-x-circle-fill"></i>
                                            </button>
                                        </form>
                                    }
                                </div>
                            }
                        }
                        else
                        {
                            <p class="text-muted small mb-2 ps-1">Be the first to comment!</p>
                        }

                        @if (currentUser != null)
                        {
                            <!-- Add Comment form -->
                            <form asp-controller="Post" asp-action="AddComment" method="post" class="mt-2">
                                <input type="hidden" name="postId" value="@post.Id" />
                                <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                                <div class="input-group">
                                    <input type="text" name="content" class="form-control form-control-sm" placeholder="Write a comment..." required />
                                    <button class="btn btn-retro-primary btn-sm" type="submit">Comment</button>
                                </div>
                            </form>
                        }
                    </div>
                </div>
            }
        }
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Setup AJAX Likers
            $('.btn-like-ajax').click(function() {
                var btn = $(this);
                var postId = btn.data('post-id');
                
                // Disable button during requests
                btn.prop('disabled', true);
                
                $.ajax({
                    url: '/api/LikesApi/toggle/' + postId,
                    type: 'POST',
                    headers: {
                        // Anti forgery token if needed, but since we are doing simple API with cookie auth:
                        // standard Identity handles cookies.
                    },
                    success: function(data) {
                        btn.find('.likes-count').text(data.count);
                        if (data.liked) {
                            btn.addClass('liked');
                            btn.find('i').removeClass('bi-heart').addClass('bi-heart-fill');
                        } else {
                            btn.removeClass('liked');
                            btn.find('i').removeClass('bi-heart-fill').addClass('bi-heart');
                        }
                    },
                    error: function(xhr, status, error) {
                        console.error("Error liking post:", error);
                        alert("Could not update like. Please sign in again.");
                    },
                    complete: function() {
                        btn.prop('disabled', false);
                    }
                });
            });
        });
    </script>
}
