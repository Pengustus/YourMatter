@model YourMatter.Models.Account.RegisterViewModel
@{
    ViewData["Title"] = "Register";
}

<div class="row justify-content-center">
    <div class="col-md-7 col-lg-6">
        <div class="custom-card shadow-lg mt-3 border-top border-4 border-accent">
            <div class="panel-header-retro panel-header-orange">
                <span><i class="bi bi-person-plus-fill me-2"></i>Create New Account</span>
                <small class="text-white-50">yourmatter</small>
            </div>

            <p class="text-muted text-center mb-4">Join our community! Setup your nostalgic profile in seconds.</p>

            <form asp-controller="Account" asp-action="Register" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="DisplayName" class="form-label fw-semibold">Display Name</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light"><i class="bi bi-person"></i></span>
                            <input asp-for="DisplayName" class="form-control" placeholder="e.g. Tom, RetroCoder" />
                        </div>
                        <span asp-validation-for="DisplayName" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Location" class="form-label fw-semibold">Location</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light"><i class="bi bi-geo-alt"></i></span>
                            <input asp-for="Location" class="form-control" placeholder="e.g. London, UK" />
                        </div>
                        <span asp-validation-for="Location" class="text-danger small"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label fw-semibold">Email Address</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light"><i class="bi bi-envelope"></i></span>
                        <input asp-for="Email" class="form-control" placeholder="name@example.com" />
                    </div>
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Password" class="form-label fw-semibold">Password</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light"><i class="bi bi-lock"></i></span>
                            <input asp-for="Password" class="form-control" type="password" placeholder="Min 6 chars" />
                        </div>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6 mb-4">
                        <label asp-for="ConfirmPassword" class="form-label fw-semibold">Confirm Password</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light"><i class="bi bi-lock-fill"></i></span>
                            <input asp-for="ConfirmPassword" class="form-control" type="password" placeholder="Confirm password" />
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>
                </div>

                <div class="d-grid mb-3">
                    <button type="submit" class="btn btn-retro-accent py-2"><i class="bi bi-person-check-fill me-2"></i>Sign Up & Start Connecting</button>
                </div>
            </form>

            <div class="text-center pt-2 border-top">
                <span class="text-muted small">Already a member?</span>
                <a asp-controller="Account" asp-action="Login" class="text-primary fw-semibold small ms-1">Login here <i class="bi bi-arrow-right-short"></i></a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
