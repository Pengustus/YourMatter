@model YourMatter.Models.Account.LoginViewModel
@{
    ViewData["Title"] = "Login";
}

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="custom-card shadow-lg mt-4 border-top border-4 border-primary">
            <div class="panel-header-retro">
                <span><i class="bi bi-box-arrow-in-right me-2"></i>Member Login</span>
                <small class="text-white-50">yourmatter</small>
            </div>

            <p class="text-muted text-center mb-4">Welcome back! Sign in to connect with friends.</p>

            <form asp-controller="Account" asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label fw-semibold">Email Address</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light"><i class="bi bi-envelope"></i></span>
                        <input asp-for="Email" class="form-control" placeholder="name@example.com" />
                    </div>
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label fw-semibold">Password</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light"><i class="bi bi-lock"></i></span>
                        <input asp-for="Password" class="form-control" type="password" placeholder="••••••" />
                    </div>
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="mb-4 d-flex justify-content-between align-items-center">
                    <div class="form-check">
                        <input asp-for="RememberMe" class="form-check-input" />
                        <label asp-for="RememberMe" class="form-check-label text-secondary small">Remember me</label>
                    </div>
                </div>

                <div class="d-grid mb-3">
                    <button type="submit" class="btn btn-retro-primary py-2"><i class="bi bi-box-arrow-in-right me-2"></i>Sign In</button>
                </div>
            </form>

            <div class="text-center pt-2 border-top">
                <span class="text-muted small">New to YourMatter?</span>
                <a asp-controller="Account" asp-action="Register" class="text-accent fw-semibold small ms-1">Create an account <i class="bi bi-arrow-right-short"></i></a>
            </div>
        </div>

        <div class="custom-card bg-light border-0 text-center py-3">
            <span class="small text-muted"><i class="bi bi-info-circle me-1"></i> Demo accounts seeded: <strong>tom@myspace.com</strong>, <strong>kelly@yourmatter.com</strong> (Pass: standard seeded format in DB seed: TomPass123!, KellyPass123!)</span>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
