@{
    ViewData["Title"] = "400 - Bad Request";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="custom-card shadow-lg error-retro-container mt-4 border-top border-4 border-warning">
            <div class="error-code-neon" style="color: var(--accent-color);">400</div>
            <h2 class="fw-bold mb-3"><i class="bi bi-exclamation-triangle-fill text-warning me-2"></i>Bad Request</h2>
            <p class="text-secondary mb-4">
                The server could not understand the request. This might be due to invalid parameters or form submission mismatch.
            </p>
            <div class="d-flex justify-content-center gap-3">
                <a asp-controller="Home" asp-action="Index" class="btn btn-retro-primary">
                    <i class="bi bi-house-door-fill me-1"></i>Go Home
                </a>
            </div>
        </div>
    </div>
</div>
