@{
    ViewData["Title"] = "401 - Unauthorized";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="custom-card shadow-lg error-retro-container mt-4 border-top border-4 border-danger">
            <div class="error-code-neon" style="color: var(--danger-color); text-shadow: 0 0 20px rgba(239, 68, 68, 0.15);">401</div>
            <h2 class="fw-bold mb-3"><i class="bi bi-shield-lock-fill text-danger me-2"></i>Access Denied</h2>
            <p class="text-secondary mb-4">
                You must be logged in to access this profile, manage friends, or interact with posts.
            </p>
            <div class="d-flex justify-content-center gap-3">
                <a asp-controller="Account" asp-action="Login" class="btn btn-retro-primary">
                    <i class="bi bi-box-arrow-in-right me-1"></i>Login
                </a>
                <a asp-controller="Account" asp-action="Register" class="btn btn-retro-accent">
                    <i class="bi bi-person-plus-fill me-1"></i>Join Free
                </a>
            </div>
        </div>
    </div>
</div>
