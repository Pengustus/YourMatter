<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - YourMatter</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/YourMatter.styles.css" asp-append-version="true" />
</head>
<body>
    <header class="sticky-top">
        <nav class="navbar navbar-expand-lg navbar-dark navbar-custom">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center" asp-controller="Home" asp-action="Index">
                    <span class="brand-logo-retro"><i class="bi bi-rocket-takeoff-fill"></i></span>
                    <span class="brand-text">your<span class="text-accent">matter</span></span>
                </a>
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent" 
                        aria-controls="navbarContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarContent">
                    <form class="d-flex mx-auto navbar-search-form my-2 my-lg-0" method="get" asp-controller="Profile" asp-action="Browse">
                        <div class="input-group">
                            <span class="input-group-text bg-transparent border-end-0 text-muted">
                                <i class="bi bi-search"></i>
                            </span>
                            <input class="form-control border-start-0 ps-0" type="search" placeholder="Search members..." aria-label="Search" name="searchTerm" value="@Context.Request.Query["searchTerm"]">
                            <button class="btn btn-search-submit" type="submit">Search</button>
                        </div>
                    </form>

                    <ul class="navbar-nav ms-auto align-items-lg-center">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house-door-fill d-none d-lg-inline me-1"></i>Home
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Profile" asp-action="Browse">
                                <i class="bi bi-people-fill d-none d-lg-inline me-1"></i>Browse
                            </a>
                        </li>
                        
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Friends" asp-action="Index">
                                    <i class="bi bi-person-heart d-none d-lg-inline me-1"></i>Friends
                                    @* We could optionally show a count, but keeping it clean *@
                                </a>
                            </li>
                            <li class="nav-item me-lg-2">
                                <a class="nav-link" asp-controller="Profile" asp-action="Index" asp-route-id="">
                                    <i class="bi bi-person-badge-fill d-none d-lg-inline me-1"></i>My Profile
                                </a>
                            </li>

                            @if (User.IsInRole("Administrator"))
                            {
                                <li class="nav-item me-lg-2">
                                    <span class="badge badge-admin-portal" title="You are logged in as Administrator">
                                        <i class="bi bi-shield-lock-fill"></i> Admin
                                    </span>
                                </li>
                            }

                            <li class="nav-item ms-lg-2 mt-2 mt-lg-0">
                                <form asp-controller="Account" asp-action="Logout" method="post" id="logoutForm" class="d-inline">
                                    <button type="submit" class="btn btn-logout-nav btn-sm w-100">
                                        <i class="bi bi-box-arrow-right me-1"></i>Logout
                                    </button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item ms-lg-2">
                                <a class="btn btn-login-nav btn-sm w-100 mb-2 mb-lg-0" asp-controller="Account" asp-action="Login">
                                    <i class="bi bi-box-arrow-in-right me-1"></i>Login
                                </a>
                            </li>
                            <li class="nav-item ms-lg-2">
                                <a class="btn btn-register-nav btn-sm w-100" asp-controller="Account" asp-action="Register">
                                    <i class="bi bi-person-plus-fill me-1"></i>Join Free
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="main-container container py-4">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show custom-alert animate-fade-in" role="alert">
                <div class="d-flex align-items-center">
                    <i class="bi bi-check-circle-fill me-2 fs-5"></i>
                    <div>@TempData["SuccessMessage"]</div>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show custom-alert animate-fade-in" role="alert">
                <div class="d-flex align-items-center">
                    <i class="bi bi-exclamation-triangle-fill me-2 fs-5"></i>
                    <div>@TempData["ErrorMessage"]</div>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="footer py-3 mt-auto text-muted">
        <div class="container text-center">
            <div class="d-flex flex-column flex-sm-row justify-content-between align-items-center gap-2">
                <span>&copy; @DateTime.UtcNow.Year - <strong>your<span class="text-accent">matter</span></strong> - Retro Social Club.</span>
                <div class="footer-links">
                    <a asp-controller="Home" asp-action="Privacy">Privacy Policy</a>
                    <span class="mx-2 text-muted">|</span>
                    <a href="mailto:support@yourmatter.com">Get Support</a>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
